    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/**/*", "test/**/*", "vitest.config.ts", "tsup.config.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
